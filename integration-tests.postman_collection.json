{
	"info": {
		"_postman_id": "9d8ceb83-6d2e-4356-97dd-8e89244332af",
		"name": "AgroCDDotnet Todo Integration Tests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Database health is ok\", function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.status).to.equal('ok');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Host",
						"value": "{{host_header}}",
						"type": "text"
					}
				],
				"url": {
					"protocol": "http",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"healthz"
					]
				}
			},
			"response": []
		},
		{
			"name": "Create Todo",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"const jsonData = pm.response.json();",
							"pm.collectionVariables.set('todo_id', jsonData.id);",
							"pm.collectionVariables.set('todo_title', jsonData.title);",
							"",
							"pm.test(\"Created todo has expected shape\", function () {",
							"    pm.expect(jsonData.title).to.include('Postman todo');",
							"    pm.expect(jsonData.isCompleted).to.equal(false);",
							"    pm.expect(jsonData.createdAtUtc).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Host",
						"value": "{{host_header}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"Postman todo {{$guid}}\",\n  \"isCompleted\": false\n}"
				},
				"url": {
					"protocol": "http",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"todos"
					]
				}
			},
			"response": []
		},
		{
			"name": "Get Todo",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Fetched todo matches created id\", function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.id).to.equal(pm.collectionVariables.get('todo_id'));",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Host",
						"value": "{{host_header}}",
						"type": "text"
					}
				],
				"url": {
					"protocol": "http",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"todos",
						"{{todo_id}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Update Todo",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Todo is updated\", function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.isCompleted).to.equal(true);",
							"    pm.expect(jsonData.updatedAtUtc).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Host",
						"value": "{{host_header}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"Updated {{todo_title}}\",\n  \"isCompleted\": true\n}"
				},
				"url": {
					"protocol": "http",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"todos",
						"{{todo_id}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Delete Todo",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 204\", function () {",
							"    pm.response.to.have.status(204);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Host",
						"value": "{{host_header}}",
						"type": "text"
					}
				],
				"url": {
					"protocol": "http",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"todos",
						"{{todo_id}}"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "localhost",
			"type": "string"
		},
		{
			"key": "host_header",
			"value": "dev.local",
			"type": "string"
		}
	]
}
